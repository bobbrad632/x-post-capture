{
  "manifest_version": 3,
  "name": "X Post Capture",
  "version": "1.4.0",
  "description": "On X (Twitter), copy any post as a pixel-perfect PNG to your clipboard — same look as on screen, ready to paste elsewhere.",
  "minimum_chrome_version": "114",
  "permissions": ["clipboardWrite", "sidePanel", "storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*", "<all_urls>"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "X Post Capture — open preview panel (last copied post)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
